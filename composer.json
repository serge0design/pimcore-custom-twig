{
    "name": "serge0design/pimcore-custom-twig",
    "license": "GPL-3.0-or-later",
    "type": "pimcore-bundle",
    "keywords": [
        "pimcore",
        "twig"
    ],
    "description": "A collection of twig Extensions/Filters and Tests. This Bundle is still a development version and not recommended for any other use.",
    "homepage": "https://github.com/serge0design/pimcore-custom-twig.git",
    "authors": [
        {
            "name": "serge.design - Serge",
            "email": "github@serge.design",
            "homepage": "https://serge-design.ch",
            "role": "Developer"
        }
    ],
    "autoload": {
        "psr-4": {
            "CustomTwigBundle\\": "src/CustomTwigBundle"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CustomTwigBundle": "src/CustomTwigBundle"
        }
    },
    "extra": {
        "pimcore": {
            "bundles": [
                "CustomTwigBundle\\CustomTwigBundle"
            ]
        }
    },
    "require": {
        "ext-intl": "*",
        "ext-mbstring": "*",
        "pimcore/pimcore": "^10.0",
        "symfony/ux-twig-component": "^2.7",
        "twig/extra-bundle": "^3.5",
        "twig/string-extra": "^3.5"
    },
    "require-dev": {}
}
